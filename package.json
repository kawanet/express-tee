{
  "name": "express-tee",
  "description": "Express middleware to cache contents on file system",
  "version": "1.2.2",
  "author": "Yusuke Kawasaki <u-suke@kawa.net>",
  "bugs": {
    "url": "https://github.com/kawanet/express-tee/issues"
  },
  "contributors": [
    "Yusuke Kawasaki <u-suke@kawa.net>"
  ],
  "dependencies": {
    "express-intercept": "^1.2.2"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-sucrase": "^5.1.0",
    "@types/express": "^4.17.17",
    "@types/express4": "npm:@types/express@^4",
    "@types/express5": "npm:@types/express@^5",
    "@types/node": "^24.12.2",
    "@types/supertest": "^7.2.0",
    "express": "^4.21.1",
    "express4": "npm:express@^4",
    "express5": "npm:express@^5",
    "rollup": "^4.60.2",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "require": "./dist/express-tee.cjs",
      "import": {
        "types": "./types/express-tee.d.ts",
        "default": "./dist/express-tee.mjs"
      }
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/express-tee.cjs",
    "dist/express-tee.mjs",
    "lib/*.ts",
    "types/*.d.ts"
  ],
  "homepage": "https://github.com/kawanet/express-tee#readme",
  "keywords": [
    "dump",
    "expressjs",
    "middleware",
    "mirror",
    "tee"
  ],
  "license": "MIT",
  "main": "./dist/express-tee.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kawanet/express-tee.git"
  },
  "scripts": {
    "build": "make -C builder",
    "fixpack": "fixpack",
    "prepack": "if node -v | grep -q '^v20'; then echo 'ERROR: packing is not allowed on Node 20'; exit 1; fi",
    "prepare": "if node -v | grep -q '^v20'; then :; else make -C builder clean all test; fi",
    "test": "make -C builder test"
  },
  "sideEffects": false,
  "type": "module",
  "types": "types/express-tee.d.ts"
}
